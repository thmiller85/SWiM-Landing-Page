# Server Configuration
PORT=3000
NODE_ENV=development

# Database (REQUIRED)
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Google Analytics Configuration
# Note: Basic GA tracking is configured in client/index.html with ID: G-YJ9EKPZ80K
# No environment variables needed for basic tracking

# Optional: Google Analytics Data API (for server-side analytics in CMS)
# Required only if you want to fetch GA data programmatically in the CMS dashboard
# Setup guide: https://developers.google.com/analytics/devguides/reporting/data/v1/quickstart
# GA_PROPERTY_ID=YOUR_GA_PROPERTY_ID
# GA_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# GA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# Meta (Facebook) Conversions API
# The browser Meta Pixel (ID 1727254495132850) is hardcoded in client/index.html
# and needs no env var. The server-side Conversions API needs a System-User
# access token generated in Meta Events Manager > Data Sources > your pixel >
# Settings > Conversions API > "Generate access token".
# Without META_CAPI_ACCESS_TOKEN the server CAPI call safely no-ops and only the
# browser pixel fires.
# META_CAPI_ACCESS_TOKEN=YOUR_SYSTEM_USER_ACCESS_TOKEN
# Optional: pixel ID override (defaults to the value hardcoded in index.html)
# META_PIXEL_ID=1727254495132850
# Optional: a test event code (Events Manager > Test Events) to verify server
# events during setup. Leave blank/remove in production.
# META_CAPI_TEST_EVENT_CODE=TEST12345